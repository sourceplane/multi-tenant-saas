          "name": "ensure-pages-project",
          "phase": "main",
          "run": "if [ \"dev\" != \"production\" ] || [ \"${GITHUB_REF:-}\" != \"refs/heads/main\" ]; then\n  echo \"::notice::SKIPPED: Cloudflare Pages project reconciliation for web-console in dev on ${GITHUB_REF:-local} (not production branch).\"\n  exit 0\nfi\n\necho \"::group::Validate Cloudflare credentials\"\n: \"${CLOUDFLARE_ACCOUNT_ID:?CLOUDFLARE_ACCOUNT_ID is required for deployment}\"\n: \"${CLOUDFLARE_API_TOKEN:?CLOUDFLARE_API_TOKEN is required for deployment}\"\necho \"CLOUDFLARE_ACCOUNT_ID and CLOUDFLARE_API_TOKEN are set.\"\necho \"::endgroup::\"\n\napi_root=\"https://api.cloudflare.com/client/v4/accounts/${CLOUDFLARE_ACCOUNT_ID}/pages/projects\"\nresponse_file=\"${RUNNER_TEMP:-/tmp}/cloudflare-pages-project.json\"\nstatus=\"$(curl -sS -o \"${response_file}\" -w \"%{http_code}\" \\\n  -H \"Authorization: Bearer ${CLOUDFLARE_API_TOKEN}\" \\\n  -H \"Content-Type: application/json\" \\\n  \"${api_root}/sourceplane-web-console\")\"\n\nif [ \"${status}\" = \"200\" ]; then\n  echo \"Pages project sourceplane-web-console already exists.\"\nelif [ \"${status}\" = \"404\" ]; then\n  curl -sS --fail -X POST \\\n    -H \"Authorization: Bearer ${CLOUDFLARE_API_TOKEN}\" \\\n    -H \"Content-Type: application/json\" \\\n    --data '{\"name\":\"sourceplane-web-console\",\"production_branch\":\"main\"}' \\\n    \"${api_root}\" \u003e/dev/null\n  echo \"Created Pages project sourceplane-web-console.\"\nelse\n  cat \"${response_file}\"\n  exit 1\nfi\n\ncurl -sS --fail -X PATCH \\\n  -H \"Authorization: Bearer ${CLOUDFLARE_API_TOKEN}\" \\\n  -H \"Content-Type: application/json\" \\\n  --data '{\"production_branch\":\"main\"}' \\\n  \"${api_root}/sourceplane-web-console\" \u003e/dev/null\n",
