{
  "name": "@saas/web-console-next-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@saas/eslint-config": "workspace:*",
    "@saas/tsconfig": "workspace:*",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [".ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "^@web-console-next/(.*)$": "<rootDir>/../../apps/web-console-next/src/$1.ts"
    },
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "useESM": true }]
    },
    "testMatch": ["<rootDir>/src/**/*.test.ts"]
  }
}
