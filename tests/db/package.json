{
  "name": "@saas/db-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@saas/eslint-config": "workspace:*",
    "@saas/tsconfig": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@saas/db": "workspace:*"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [".ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "^@saas/db$": "<rootDir>/../../packages/db/src/index.ts",
      "^@saas/db/runner$": "<rootDir>/../../packages/db/src/runner/index.ts",
      "^@saas/db/hyperdrive$": "<rootDir>/../../packages/db/src/hyperdrive/index.ts",
      "^@saas/db/identity$": "<rootDir>/../../packages/db/src/identity/index.ts",
      "^@saas/db/membership$": "<rootDir>/../../packages/db/src/membership/index.ts",
      "^@saas/db/events$": "<rootDir>/../../packages/db/src/events/index.ts",
      "^@saas/db/projects$": "<rootDir>/../../packages/db/src/projects/index.ts",
      "^@saas/db/(.*)$": "<rootDir>/../../packages/db/src/$1.ts"
    },
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "useESM": true }]
    },
    "testMatch": ["<rootDir>/src/**/*.test.ts"]
  }
}
